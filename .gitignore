# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Working files (brand source assets, drafts, notes — not part of the site)
/*.docx
/*.jpg
/Hessentials_Symbol_Monogram_HESS_v1.png
/Symbol/
/Wordmark/
/COPYRIGHT-REGISTRATION-GUIDE.md
/STYLE-CHATEAU-AUDIT.md
/public/*.docx
